# =============================================================================
# PARAM Hermes Environment — NAS Docker Deployment
# =============================================================================
# Copy to: deploy/nas/hermes-data/.env
# Then: chmod 600 hermes-data/.env
# =============================================================================

# ---------------------------------------------------------------------------
# Provider Routing — CHOOSE ONE SECTION BELOW
# ---------------------------------------------------------------------------

# --- Option A: OpenRouter (recommended for NAS — no local proxy needed) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Model set in config.yaml: model.provider = openrouter
# Base URL set in config.yaml: model.base_url = https://openrouter.ai/api/v1

# --- Option B: Anthropic Direct ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# Model set in config.yaml: model.provider = anthropic

# --- Option C: OpenAI Direct ---
# OPENAI_API_KEY=sk-your-key-here
# Model set in config.yaml: model.provider = openai

# --- Option D: TokenEye on NAS (uncomment tokeneye service in docker-compose.yml) ---
# OPENCODE_GO_API_KEY=managed-by-tokeneye
# OPENCODE_GO_BASE_URL=http://127.0.0.1:8787/zen/go/v1

# ---------------------------------------------------------------------------
# Messaging — Telegram (REQUIRED)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=
TELEGRAM_HOME_CHANNEL_NAME=PARAM

# ---------------------------------------------------------------------------
# Memory — Self-Learning (optional, pick one provider)
# ---------------------------------------------------------------------------
# Mem0: https://mem0.ai
# MEM0_API_KEY=m0-your-key-here

# Honcho: https://app.honcho.dev
# HONCHO_API_KEY=your-key-here

# Supermemory: https://supermemory.ai
# SUPERMEMORY_API_KEY=your-key-here

# ---------------------------------------------------------------------------
# Optional: Additional Platforms
# ---------------------------------------------------------------------------
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SIGNAL_CLI_PATH=
# MATRIX_ACCESS_TOKEN=
